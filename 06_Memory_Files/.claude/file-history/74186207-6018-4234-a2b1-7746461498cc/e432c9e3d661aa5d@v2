#!/bin/bash
# Run Steam in a virtual X server (Xvfb)

# Kill any existing Steam processes
pkill -f steam

# Start Xvfb on display :99 with 24-bit color depth
Xvfb :99 -screen 0 1024x768x24 &
XVFB_PID=$!
sleep 2

# Set display to the virtual one
export DISPLAY=:99

# Force software rendering
export LIBGL_ALWAYS_SOFTWARE=1
export MESA_LOADER_DRIVER_OVERRIDE=llvmpipe

# Launch Steam
steam "$@"

# Clean up Xvfb when Steam exits
kill $XVFB_PID 2>/dev/null