import os
import shutil
from datetime import datetime

def backup_file(filepath):
    """Create timestamped backup of file"""
    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    backup_path = f"{filepath}.backup.{timestamp}"
    shutil.copy2(filepath, backup_path)
    print(f"✅ Backed up {filepath} to {backup_path}")
    return backup_path

def fix_orchestrator():
    """Apply critical fixes to dialer_orchestrator.py"""
    filepath = "dialer_orchestrator.py"
    backup_file(filepath)

    with open(filepath, 'r') as f:
        content = f.read()

    # Fix 1: Change bot manager import (line 32)
    old_import = "from bot_pool_manager import BotPoolManager  # Pipecat bots with built-in recording"
    new_import = "from avr_bot_pool_manager import AVRBotPoolManager as BotPoolManager  # AVR Docker bots"
    content = content.replace(old_import, new_import)

    # Fix 2: Reduce dial ratio (lines 74-75)
    content = content.replace(
        "min_dial_ratio: float = 3.0,",
        "min_dial_ratio: float = 1.2,  # Conservative for stability"
    )
    content = content.replace(
        "max_dial_ratio: float = 5.0,",
        "max_dial_ratio: float = 2.0,  # Prevent overload"
    )

    # Fix 3: Dynamic AVR bot detection (around line 390)
    old_avr_check = """if self.bot_pool is None:
            # Using AVR bots managed externally - assume 20 available
            available_bots = 20"""

    new_avr_check = """if self.bot_pool is None:
            # Using AVR bots - dynamically count running containers
            try:
                import docker
                client = docker.from_env()
                containers = client.containers.list(filters={"name": "avr-bot", "status": "running"})
                available_bots = len(containers)
                logger.info(f"📊 AVR Docker bots available: {available_bots}")
            except Exception as e:
                logger.error(f"Failed to count AVR bots: {e}, assuming 3")
                available_bots = 3  # Safe fallback"""

    content = content.replace(old_avr_check, new_avr_check)

    # Fix 4: Add timeout to database operations (around line 931)
    old_gather = """await asyncio.gather(
                self.db.log_call("""

    new_gather = """await asyncio.wait_for(
            asyncio.gather(
                self.db.log_call("""

    content = content.replace(old_gather, new_gather)

    # Add timeout parameter after the gather block
    content = content.replace(
        "            )\n            )",
        "            )\n            ),\n            timeout=30.0  # Prevent database lock hanging"
    )

    # Fix 5: Add await to mark_bot_idle (line 871)
    content = content.replace(
        "self.bot_pool.mark_bot_idle(call_attempt.bot_port)",
        "await self.bot_pool.mark_bot_idle(call_attempt.bot_port)"
    )

    # Fix 6: Add circuit breaker initialization
    init_section = "def __init__(self"
    if "consecutive_failures" not in content:
        content = content.replace(
            "        self.ami_client: Optional[AMIClient] = None",
            """        self.ami_client: Optional[AMIClient] = None

        # Circuit breaker for stability
        self.consecutive_failures = 0
        self.max_failures_before_pause = 5"""
        )

    with open(filepath, 'w') as f:
        f.write(content)

    print("✅ Fixed dialer_orchestrator.py")

def fix_avr_bot_manager():
    """Make mark_bot_idle async in AVRBotPoolManager"""
    filepath = "avr_bot_pool_manager.py"

    if not os.path.exists(filepath):
        print("⚠️  avr_bot_pool_manager.py not found, skipping")
        return

    backup_file(filepath)

    with open(filepath, 'r') as f:
        content = f.read()

    # Make mark_bot_idle async
    content = content.replace(
        "def mark_bot_idle(self, port: int):",
        "async def mark_bot_idle(self, port: int):"
    )

    with open(filepath, 'w') as f:
        f.write(content)

    print("✅ Fixed avr_bot_pool_manager.py")

def fix_database_async():
    """Add optimizations to database connection"""
    filepath = "dialer_db_async.py"
    backup_file(filepath)

    with open(filepath, 'r') as f:
        content = f.read()

    # Add database optimizations after WAL mode
    old_init = """await self.db.execute("PRAGMA journal_mode=WAL")
        await self.db.execute("PRAGMA busy_timeout=30000")"""

    new_init = """await self.db.execute("PRAGMA journal_mode=WAL")
        await self.db.execute("PRAGMA busy_timeout=60000")  # 60 seconds
        await self.db.execute("PRAGMA cache_size=-64000")   # 64MB cache
        await self.db.execute("PRAGMA temp_store=MEMORY")   # RAM for temp
        await self.db.execute("PRAGMA synchronous=NORMAL")  # Faster writes"""

    content = content.replace(old_init, new_init)

    # Change INSERT to INSERT OR REPLACE (line ~424)
    content = content.replace(
        "INSERT INTO call_log (",
        "INSERT OR REPLACE INTO call_log ("
    )

    with open(filepath, 'w') as f:
        f.write(content)

    print("✅ Fixed dialer_db_async.py")

