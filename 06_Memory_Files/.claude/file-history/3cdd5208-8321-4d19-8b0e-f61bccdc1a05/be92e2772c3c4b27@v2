import React, { useState, useEffect } from 'react';
import { Link } from 'react-router-dom';
import { 
  Phone, Search, Download, ExternalLink, 
  PlayCircle, FileText, Clock, User,
  PhoneCall, PhoneOff, Filter, ChevronLeft, ChevronRight
} from 'lucide-react';
import axios from 'axios';
import './CallHistory.css';

function CallHistory({ apiUrl }) {
  const [calls, setCalls] = useState([]);
  const [activeCalls, setActiveCalls] = useState([]);
  const [loading, setLoading] = useState(false);
  const [searchQuery, setSearchQuery] = useState('');
  const [currentPage, setCurrentPage] = useState(1);
  const [totalPages, setTotalPages] = useState(1);
  const [filterStatus, setFilterStatus] = useState('all');
  const [filterDisposition, setFilterDisposition] = useState('all');

  const fetchCalls = async (page = 1) => {
    setLoading(true);
    try {
      const response = await axios.get(`${apiUrl}/calls/history`, {
        params: { page, limit: 50 }
      });
      const callsArray = response.data.calls || response.data;
      setCalls(callsArray);
      setCurrentPage(page);
      // Calculate total pages if API provides count
      if (response.data.total) {
        setTotalPages(Math.ceil(response.data.total / 50));
      }
    } catch (error) {
      console.error('Failed to fetch calls:', error);
      // Mock data for demo
      const mockCalls = Array.from({length: 20}, (_, i) => ({
        id: 1000 + i,
        uuid: `call-${1000 + i}`,
        phone_number: `555-${String(Math.floor(Math.random() * 900) + 100)}-${String(Math.floor(Math.random() * 9000) + 1000)}`,
        lead_name: `Lead ${i + 1}`,
        campaign_name: 'Solar Sales Q4',
        start_time: new Date(Date.now() - Math.random() * 86400000).toISOString(),
        duration: Math.floor(Math.random() * 600),
        status: ['completed', 'no_answer', 'busy', 'failed'][Math.floor(Math.random() * 4)],
        disposition: ['INTERESTED', 'NOT_INTERESTED', 'CALLBACK', 'DNC', null][Math.floor(Math.random() * 5)],
        bot_port: 9092 + (i % 20),
        has_transcript: Math.random() > 0.3,
        has_recording: Math.random() > 0.5
      }));
      setCalls(mockCalls);
    } finally {
      setLoading(false);
    }
  };

  const fetchActiveCalls = async () => {
    try {
      const response = await axios.get(`${apiUrl}/calls/active`);
      const activeCallsArray = response.data.calls || response.data;
      setActiveCalls(activeCallsArray);
    } catch (error) {
      console.error('Failed to fetch active calls:', error);
      setActiveCalls([]);
    }
  };

  useEffect(() => {
    fetchCalls();
    fetchActiveCalls();
    
    // Refresh active calls more frequently
    const interval = setInterval(fetchActiveCalls, 5000);
    return () => clearInterval(interval);
  }, []);

  const exportCalls = async () => {
    try {
      const response = await axios.get(`${apiUrl}/export/calls`, {
        responseType: 'blob'
      });
      
      const url = window.URL.createObjectURL(new Blob([response.data]));
      const link = document.createElement('a');
      link.href = url;
      link.setAttribute('download', `call_history_${Date.now()}.csv`);
      document.body.appendChild(link);
      link.click();
      link.remove();
    } catch (error) {
      console.error('Failed to export calls:', error);
    }
  };

  const formatDuration = (seconds) => {
    if (!seconds) return '0:00';
    const mins = Math.floor(seconds / 60);
    const secs = seconds % 60;
    return `${mins}:${secs.toString().padStart(2, '0')}`;
  };

  const formatTime = (isoString) => {
    if (!isoString) return '-';
    const date = new Date(isoString);
    return date.toLocaleString();
  };

  const filteredCalls = calls.filter(call => {
    // Search filter
    if (searchQuery && !JSON.stringify(call).toLowerCase().includes(searchQuery.toLowerCase())) {
      return false;
    }
    
    // Status filter
    if (filterStatus !== 'all' && call.status !== filterStatus) {
      return false;
    }
    
    // Disposition filter
    if (filterDisposition !== 'all' && call.disposition !== filterDisposition) {
      return false;
    }
    
    return true;
  });

  return (
    <div className="call-history">
      <div className="history-header">
        <h2>Call History</h2>
        <div className="header-actions">
          <button 
            className="btn-export"
            onClick={exportCalls}
          >
            <Download size={16} />
            Export CSV
          </button>
        </div>
      </div>

      {/* Active Calls Section */}
      {activeCalls.length > 0 && (
        <div className="active-calls-section">
          <h3 className="section-title">
            <PhoneCall className="pulse" />
            Active Calls ({activeCalls.length})
          </h3>
          <div className="active-calls-grid">
            {activeCalls.map(call => (
              <div key={call.uuid} className="active-call-card">
                <div className="call-header">
                  <span className="phone-number">{call.phone_number}</span>
                  <span className="duration-live">
                    <Clock size={14} />
                    {formatDuration(call.duration)}
                  </span>
                </div>
                <div className="call-details">
                  <span className="lead-name">
                    <User size={14} />
                    {call.lead_name}
                  </span>
                  <span className="bot-info">Bot {call.bot_port}</span>
                </div>
                <div className="call-actions">
                  <Link 
                    to={`/call/${call.uuid}`}
                    className="btn-monitor"
                  >
                    Monitor
                  </Link>
                  <button className="btn-hangup">
                    <PhoneOff size={14} />
                  </button>
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      {/* Filters */}
      <div className="history-filters">
        <div className="search-box">
          <Search size={16} />
          <input
            type="text"
            placeholder="Search by phone, name, campaign..."
            value={searchQuery}
            onChange={(e) => setSearchQuery(e.target.value)}
          />
        </div>
        
        <select 
          value={filterStatus}
          onChange={(e) => setFilterStatus(e.target.value)}
          className="filter-select"
        >
          <option value="all">All Status</option>
          <option value="completed">Completed</option>
          <option value="no_answer">No Answer</option>
          <option value="busy">Busy</option>
          <option value="failed">Failed</option>
        </select>
        
        <select 
          value={filterDisposition}
          onChange={(e) => setFilterDisposition(e.target.value)}
          className="filter-select"
        >
          <option value="all">All Dispositions</option>
          <option value="INTERESTED">Interested</option>
          <option value="NOT_INTERESTED">Not Interested</option>
          <option value="CALLBACK">Callback</option>
          <option value="DNC">DNC</option>
        </select>
      </div>

      {/* Call History Table */}
      <div className="history-table-container">
        <table className="history-table">
          <thead>
            <tr>
              <th>Time</th>
              <th>Phone</th>
              <th>Lead</th>
              <th>Campaign</th>
              <th>Duration</th>
              <th>Status</th>
              <th>Disposition</th>
              <th>Bot</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            {loading ? (
              <tr>
                <td colSpan="9" className="loading-cell">Loading...</td>
              </tr>
            ) : filteredCalls.length === 0 ? (
              <tr>
                <td colSpan="9" className="empty-cell">No calls found</td>
              </tr>
            ) : (
              filteredCalls.map(call => (
                <tr key={call.id || call.uuid}>
                  <td className="time-cell">
                    {formatTime(call.start_time)}
                  </td>
                  <td className="phone-cell">
                    <Phone size={14} />
                    {call.phone_number}
                  </td>
                  <td>{call.lead_name || '-'}</td>
                  <td>{call.campaign_name || '-'}</td>
                  <td className="duration-cell">
                    {formatDuration(call.duration)}
                  </td>
                  <td>
                    <span className={`status-badge ${call.status}`}>
                      {call.status}
                    </span>
                  </td>
                  <td>
                    {call.disposition && (
                      <span className={`disposition-badge ${call.disposition?.toLowerCase()}`}>
                        {call.disposition}
                      </span>
                    )}
                  </td>
                  <td className="bot-cell">
                    {call.bot_port}
                  </td>
                  <td className="actions-cell">
                    <Link 
                      to={`/call/${call.id || call.uuid}`}
                      className="btn-view-details"
                      title="View call details, transcript & recording"
                    >
                      <ExternalLink size={16} />
                      Details
                    </Link>
                  </td>
                </tr>
              ))
            )}
          </tbody>
        </table>
      </div>

      {/* Pagination */}
      <div className="pagination">
        <button
          className="btn-page"
          disabled={currentPage === 1}
          onClick={() => fetchCalls(currentPage - 1)}
        >
          <ChevronLeft size={16} />
          Previous
        </button>
        
        <span className="page-info">
          Page {currentPage} {totalPages > 1 && `of ${totalPages}`}
        </span>
        
        <button
          className="btn-page"
          disabled={filteredCalls.length < 50}
          onClick={() => fetchCalls(currentPage + 1)}
        >
          Next
          <ChevronRight size={16} />
        </button>
      </div>
    </div>
  );
}

export default CallHistory;