;================================ TRANSPORTS ==
[transport-tcp]
type=transport
protocol=tcp
bind=0.0.0.0:5060

; Single transport - NAT settings only apply to external IPs
[transport-udp]
type=transport
protocol=udp
bind=0.0.0.0:5060
local_net=10.0.0.0/24
external_media_address=73.139.162.13
external_signaling_address=73.139.162.13

;================================ TEMPLATES ==
[webrtc-template](!)
type=endpoint
transport=transport-udp
context=ava-context
disallow=all
allow=ulaw
allow=alaw
dtmf_mode=rfc4733
language=en
rtp_symmetric=yes
direct_media=no
force_rport=yes
rewrite_contact=yes
timers=no             ; CRITICAL: Disable session timers for AI calls (prevents 408 timeout at ~50s)
; QUALITY OPTIMIZATION: QoS for voice prioritization
tos_audio=ef          ; DSCP 46 (Expedited Forwarding) - highest voice priority
cos_audio=5           ; 802.1p Layer 2 priority
rtp_timeout=0         ; DISABLED - don't timeout on silence (AI calls have long pauses)
rtp_timeout_hold=0    ; DISABLED

