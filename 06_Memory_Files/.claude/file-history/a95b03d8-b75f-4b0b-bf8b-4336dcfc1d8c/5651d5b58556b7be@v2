#!/usr/bin/env python3
"""
Test script to make a manual call and verify tracking
"""

import requests
import json
import time

API_URL = "http://localhost:8000"

def make_test_call():
    """Make a test manual call and check tracking"""

    # Test phone number (replace with working number)
    phone_number = "+13057768712"  # Or any test number

    print("🔧 Testing Manual Call Tracking\n")

    # 1. Make the call
    print("📞 Step 1: Originating call...")
    response = requests.post(
        f"{API_URL}/calls/originate",
        json={
            "phone_number": phone_number,
            "contact_name": "Test"
        }
    )

    if response.status_code != 201:
        print(f"❌ Failed to originate call: {response.text}")
        return

    result = response.json()
    print(f"✅ Call initiated:")
    print(f"   Lead ID: {result.get('lead_id')}")
    print(f"   Campaign ID: {result.get('campaign_id')}")
    print(f"   Action ID: {result.get('action_id')}")
    print(f"   Bot Port: {result.get('bot_port')}")

    lead_id = result.get('lead_id')
    action_id = result.get('action_id')

    # 2. Check lead status
    print(f"\n📊 Step 2: Checking lead status...")
    time.sleep(2)  # Wait for call to process

    response = requests.get(f"{API_URL}/leads/{lead_id}")
    if response.status_code == 200:
        lead = response.json()
        print(f"   Lead Status: {lead.get('status')}")
        print(f"   Phone: {lead.get('phone_number')}")
    else:
        print(f"⚠️ Could not fetch lead: {response.status_code}")

    # 3. Check active calls
    print(f"\n📋 Step 3: Checking active calls...")
    response = requests.get(f"{API_URL}/calls/active")
    if response.status_code == 200:
        calls = response.json()
        matching = [c for c in calls if c.get('lead_id') == lead_id]
        if matching:
            print(f"✅ Found in active calls: {matching[0]}")
        else:
            print(f"⚠️ Not found in active calls")

    print(f"\n📝 Instructions:")
    print(f"1. Wait for call to complete (hangup)")
    print(f"2. Check lead status again - should update from CALLING")
    print(f"3. Check call history - should have entry with transcript")
    print(f"\nLead ID to track: {lead_id}")
    print(f"Action ID: {action_id}")

if __name__ == "__main__":
    make_test_call()