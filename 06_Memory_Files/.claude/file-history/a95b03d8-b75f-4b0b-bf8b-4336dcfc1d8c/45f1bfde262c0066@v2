/* Call Details Styles */
.call-details {
  padding: 20px;
  max-width: 1400px;
  margin: 0 auto;
}

.call-details.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 400px;
  color: #666;
}

.spinner {
  width: 40px;
  height: 40px;
  border: 3px solid rgba(0, 122, 255, 0.2);
  border-top-color: #007aff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.details-header {
  display: flex;
  align-items: center;
  gap: 20px;
  margin-bottom: 30px;
}

.btn-back {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 16px;
  background: rgba(255, 255, 255, 0.9);
  border: 1px solid rgba(0, 0, 0, 0.1);
  border-radius: 8px;
  color: #333;
  text-decoration: none;
  font-size: 14px;
  transition: all 0.2s;
  backdrop-filter: blur(10px);
}

.btn-back:hover {
  background: #007aff;
  color: white;
  transform: translateX(-2px);
}

.details-header h2 {
  margin: 0;
  font-size: 28px;
  font-weight: 600;
  color: #1d1d1f;
}

/* Call Summary Card */
.call-summary-card {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20px);
  border: 1px solid rgba(0, 0, 0, 0.1);
  border-radius: 16px;
  padding: 24px;
  margin-bottom: 24px;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
}

.summary-row {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 24px;
  margin-bottom: 20px;
}

.summary-row:last-child {
  margin-bottom: 0;
}

.summary-item {
  display: flex;
  align-items: flex-start;
  gap: 12px;
}

.summary-item svg {
  color: #007aff;
  margin-top: 2px;
}

.summary-item div {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.summary-item label {
  font-size: 12px;
  color: #86868b;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  font-weight: 600;
}

.summary-item span {
  font-size: 16px;
  color: #1d1d1f;
  font-weight: 500;
}

.status-badge,
.disposition-badge {
  display: inline-block;
  padding: 4px 10px;
  border-radius: 6px;
  font-size: 12px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.status-badge.answered {
  background: #34c759;
  color: white;
}

.status-badge.no_answer,
.status-badge.busy {
  background: #ff9500;
  color: white;
}

.status-badge.failed {
  background: #ff3b30;
  color: white;
}

.disposition-badge {
  background: #007aff;
  color: white;
}

.disposition-badge.interested {
  background: #34c759;
}

.disposition-badge.not_interested,
.disposition-badge.dnc {
  background: #ff3b30;
}

.disposition-badge.callback {
  background: #ff9500;
}

/* Recording Section */
.recording-section {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20px);
  border: 1px solid rgba(0, 0, 0, 0.1);
  border-radius: 16px;
  padding: 24px;
  margin-bottom: 24px;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
}

.recording-section h3 {
  display: flex;
  align-items: center;
  gap: 10px;
  margin: 0 0 20px 0;
  font-size: 20px;
  font-weight: 600;
  color: #1d1d1f;
}

.audio-player {
  width: 100%;
  max-width: 600px;
  height: 50px;
}

/* Transcript Section */
.transcript-section {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20px);
  border: 1px solid rgba(0, 0, 0, 0.1);
  border-radius: 16px;
  padding: 24px;
  margin-bottom: 24px;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
}

.transcript-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24px;
}

.transcript-header h3 {
  display: flex;
  align-items: center;
  gap: 10px;
  margin: 0;
  font-size: 20px;
  font-weight: 600;
  color: #1d1d1f;
}

.transcript-actions {
  display: flex;
  gap: 12px;
}

.btn-copy,
.btn-download {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 8px 16px;
  background: white;
  border: 1px solid rgba(0, 0, 0, 0.1);
  border-radius: 8px;
  font-size: 14px;
  font-weight: 500;
  color: #1d1d1f;
  cursor: pointer;
  transition: all 0.2s;
}

.btn-copy:hover,
.btn-download:hover {
  background: #007aff;
  color: white;
  transform: translateY(-1px);
  box-shadow: 0 4px 12px rgba(0, 122, 255, 0.2);
}

.btn-copy.copied {
  background: #34c759;
  color: white;
}

.btn-copy:disabled,
.btn-download:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

/* Transcript Content */
.transcript-content {
  max-height: 600px;
  overflow-y: auto;
  background: rgba(0, 0, 0, 0.02);
  border-radius: 12px;
  padding: 20px;
}

.transcript-line {
  padding: 12px;
  margin-bottom: 12px;
  border-radius: 8px;
  background: white;
  display: flex;
  flex-direction: column;
  gap: 8px;
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.05);
  transition: transform 0.2s;
}

.transcript-line:hover {
  transform: translateX(4px);
}

.transcript-line.agent {
  border-left: 4px solid #007aff;
}

.transcript-line.customer {
  border-left: 4px solid #34c759;
}

.transcript-line.system {
  border-left: 4px solid #86868b;
  opacity: 0.7;
}

.transcript-line .speaker {
  font-weight: 600;
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: #86868b;
}

.transcript-line.agent .speaker {
  color: #007aff;
}

.transcript-line.customer .speaker {
  color: #34c759;
}

.transcript-line .text {
  font-size: 15px;
  line-height: 1.6;
  color: #1d1d1f;
  white-space: pre-wrap;
  word-wrap: break-word;
}

.no-transcript {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 20px;
  color: #86868b;
}

.no-transcript svg {
  margin-bottom: 16px;
  opacity: 0.5;
}

.no-transcript p {
  margin: 0;
  font-size: 16px;
}

/* Notes Section */
.notes-section {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20px);
  border: 1px solid rgba(0, 0, 0, 0.1);
  border-radius: 16px;
  padding: 24px;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
}

.notes-section h3 {
  margin: 0 0 16px 0;
  font-size: 20px;
  font-weight: 600;
  color: #1d1d1f;
}

.notes-section p {
  margin: 0;
  font-size: 15px;
  line-height: 1.6;
  color: #3a3a3c;
}

/* Responsive */
@media (max-width: 768px) {
  .call-details {
    padding: 16px;
  }

  .summary-row {
    grid-template-columns: 1fr;
    gap: 16px;
  }

  .transcript-header {
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
  }

  .transcript-actions {
    width: 100%;
  }

  .btn-copy,
  .btn-download {
    flex: 1;
  }
}