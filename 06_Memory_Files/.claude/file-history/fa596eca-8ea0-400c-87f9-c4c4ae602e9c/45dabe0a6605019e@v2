import React, { useState, useEffect } from 'react';
import { Upload, Download, User, Phone, Mail, MapPin, Calendar, Filter, Search, Plus, Trash2, Edit, FileText } from 'lucide-react';
import axios from 'axios';
import './LeadManager.css';

function LeadManager({ apiUrl }) {
  const [leads, setLeads] = useState([]);
  const [campaigns, setCampaigns] = useState([]);
  const [loading, setLoading] = useState(false);
  const [filterCampaign, setFilterCampaign] = useState('all');
  const [filterStatus, setFilterStatus] = useState('all');
  const [searchQuery, setSearchQuery] = useState('');
  const [showAddModal, setShowAddModal] = useState(false);
  const [showNotesModal, setShowNotesModal] = useState(false);
  const [editingLead, setEditingLead] = useState(null);
  const [selectedLead, setSelectedLead] = useState(null);
  const [leadNotes, setLeadNotes] = useState([]);
  const [newNote, setNewNote] = useState('');
  const [newLead, setNewLead] = useState({
    phone_number: '',
    first_name: '',
    last_name: '',
    campaign_id: ''
  });

  const fetchLeads = async () => {
    setLoading(true);
    try {
      const params = {};
      if (filterCampaign !== 'all') params.campaign_id = filterCampaign;
      if (filterStatus !== 'all') params.status = filterStatus;

      const response = await axios.get(`${apiUrl}/leads`, { params });
      const leadsArray = response.data.leads || response.data;
      setLeads(leadsArray);
    } catch (error) {
      console.error('Failed to fetch leads:', error);
    }
    setLoading(false);
  };

  const fetchCampaigns = async () => {
    try {
      const response = await axios.get(`${apiUrl}/campaigns`);
      const campaignsArray = response.data.campaigns || response.data;
      setCampaigns(campaignsArray);
    } catch (error) {
      console.error('Failed to fetch campaigns:', error);
    }
  };

  useEffect(() => {
    fetchLeads();
    fetchCampaigns();
  }, [apiUrl, filterCampaign, filterStatus]);

  const addLead = async () => {
    try {
      await axios.post(`${apiUrl}/leads`, newLead);
      setShowAddModal(false);
      setNewLead({ phone_number: '', first_name: '', last_name: '', campaign_id: '' });
      fetchLeads();
    } catch (error) {
      alert(error.response?.data?.detail || 'Failed to add lead');
    }
  };

  const handleImportCSV = () => {
    const input = document.createElement('input');
    input.type = 'file';
    input.accept = '.csv';
    input.onchange = async (e) => {
      const file = e.target.files[0];
      if (!file) return;
      
      const formData = new FormData();
      formData.append('file', file);
      formData.append('campaign_id', filterCampaign === 'all' ? '1' : filterCampaign);
      
      try {
        const response = await axios.post(`${apiUrl}/leads/import`, formData, {
          headers: { 'Content-Type': 'multipart/form-data' }
        });
        alert(`Imported ${response.data.imported} leads successfully`);
        fetchLeads();
      } catch (error) {
        alert('Failed to import CSV: ' + (error.response?.data?.detail || error.message));
      }
    };
    input.click();
  };

  const handleExportCSV = async () => {
    try {
      const params = {};
      if (filterCampaign !== 'all') params.campaign_id = filterCampaign;
      if (filterStatus !== 'all') params.status = filterStatus;
      
      const response = await axios.get(`${apiUrl}/leads/export`, { 
        params,
        responseType: 'blob'
      });
      
      const url = window.URL.createObjectURL(new Blob([response.data]));
      const link = document.createElement('a');
      link.href = url;
      link.setAttribute('download', `leads_${new Date().toISOString().split('T')[0]}.csv`);
      document.body.appendChild(link);
      link.click();
      link.remove();
    } catch (error) {
      alert('Failed to export leads');
    }
  };

  const callLead = async (leadId, phoneNumber) => {
    try {
      await axios.post(`${apiUrl}/calls/originate`, {
        lead_id: leadId,
        phone_number: phoneNumber
      });
      alert('Call initiated successfully');
      fetchLeads();
    } catch (error) {
      alert('Failed to initiate call: ' + (error.response?.data?.detail || error.message));
    }
  };

  const editLead = (lead) => {
    setEditingLead(lead);
    setNewLead({
      phone_number: lead.phone_number,
      first_name: lead.first_name || '',
      last_name: lead.last_name || '',
      campaign_id: lead.campaign_id
    });
    setShowAddModal(true);
  };

  const deleteLead = async (leadId, leadName) => {
    if (!window.confirm(`Are you sure you want to delete ${leadName}?`)) {
      return;
    }

    try {
      await axios.delete(`${apiUrl}/leads/${leadId}`);
      alert('Lead deleted successfully');
      fetchLeads();
    } catch (error) {
      alert('Failed to delete lead: ' + (error.response?.data?.detail || error.message));
    }
  };

  const updateLeadStatus = async (leadId, newStatus) => {
    try {
      await axios.put(`${apiUrl}/leads/${leadId}/status`, {
        status: newStatus
      });
      // Refresh leads to show updated status
      fetchLeads();
    } catch (error) {
      alert('Failed to update lead status: ' + (error.response?.data?.detail || error.message));
    }
  };

  const showLeadNotes = async (lead) => {
    setSelectedLead(lead);
    try {
      const response = await axios.get(`${apiUrl}/leads/${lead.id}/notes`);
      setLeadNotes(response.data.notes || []);
      setShowNotesModal(true);
    } catch (error) {
      console.error('Failed to fetch notes:', error);
      setLeadNotes([]);
      setShowNotesModal(true);
    }
  };

  const addNote = async () => {
    if (!newNote.trim()) {
      alert('Please enter a note');
      return;
    }

    try {
      await axios.post(`${apiUrl}/leads/${selectedLead.id}/notes`, {
        notes: newNote
      });
      setNewNote('');
      // Refresh notes
      const response = await axios.get(`${apiUrl}/leads/${selectedLead.id}/notes`);
      setLeadNotes(response.data.notes || []);
      alert('Note added successfully');
    } catch (error) {
      alert(error.response?.data?.detail || 'Failed to add note');
    }
  };

  const filteredLeads = leads.filter(lead => {
    if (!searchQuery) return true;
    const query = searchQuery.toLowerCase();
    return (
      lead.phone_number?.includes(query) ||
      lead.first_name?.toLowerCase().includes(query) ||
      lead.last_name?.toLowerCase().includes(query)
    );
  });

  const getStatusColor = (status) => {
    const colors = {
      'NEW': '#4CAF50',
      'CALLING': '#2196F3',
      'CALLED': '#9C27B0',
      'COMPLETED': '#00BCD4',
      'FAILED': '#F44336',
      'NO_ANSWER': '#FF9800',
      'BUSY': '#FFC107'
    };
    return colors[status] || '#666';
  };

  return (
    <div className="lead-manager">
      <div className="section-header">
        <h2>Lead Management</h2>
        <div className="header-actions">
          <button className="btn-action" onClick={() => setShowAddModal(true)}>
            <Plus size={16} />
            Add Lead
          </button>
          <button className="btn-action" onClick={handleImportCSV}>
            <Upload size={16} />
            Import CSV
          </button>
          <button className="btn-action" onClick={handleExportCSV}>
            <Download size={16} />
            Export
          </button>
        </div>
      </div>

      <div className="filters-bar">
        <div className="search-box">
          <Search size={16} />
          <input
            type="text"
            placeholder="Search by name or phone..."
            value={searchQuery}
            onChange={e => setSearchQuery(e.target.value)}
          />
        </div>

        <select
          value={filterCampaign}
          onChange={e => setFilterCampaign(e.target.value)}
          className="filter-select"
        >
          <option value="all">All Campaigns</option>
          {campaigns.map(c => (
            <option key={c.id} value={c.id}>{c.name}</option>
          ))}
        </select>

        <select
          value={filterStatus}
          onChange={e => setFilterStatus(e.target.value)}
          className="filter-select"
        >
          <option value="all">All Status</option>
          <option value="NEW">New</option>
          <option value="CALLING">Calling</option>
          <option value="CALLED">Called</option>
          <option value="COMPLETED">Completed</option>
          <option value="FAILED">Failed</option>
          <option value="NO_ANSWER">No Answer</option>
          <option value="BUSY">Busy</option>
        </select>
      </div>

      <div className="leads-stats">
        <div className="stat-card">
          <span className="stat-label">Total Leads</span>
          <span className="stat-value">{leads.length}</span>
        </div>
        <div className="stat-card">
          <span className="stat-label">New</span>
          <span className="stat-value">{leads.filter(l => l.status === 'NEW').length}</span>
        </div>
        <div className="stat-card">
          <span className="stat-label">Called</span>
          <span className="stat-value">{leads.filter(l => l.status === 'CALLED').length}</span>
        </div>
        <div className="stat-card">
          <span className="stat-label">Completed</span>
          <span className="stat-value">{leads.filter(l => l.status === 'COMPLETED').length}</span>
        </div>
      </div>

      <div className="leads-table">
        <table>
          <thead>
            <tr>
              <th>Name</th>
              <th>Phone</th>
              <th>Campaign</th>
              <th>Status</th>
              <th>Attempts</th>
              <th>Last Called</th>
              <th>Next Call</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            {loading ? (
              <tr>
                <td colSpan="8" className="loading-cell">Loading leads...</td>
              </tr>
            ) : filteredLeads.length === 0 ? (
              <tr>
                <td colSpan="8" className="empty-cell">No leads found</td>
              </tr>
            ) : (
              filteredLeads.map(lead => (
                <tr key={lead.id}>
                  <td>
                    <div className="lead-name">
                      <User size={14} />
                      {lead.first_name || lead.last_name ? 
                        `${lead.first_name || ''} ${lead.last_name || ''}`.trim() : 
                        'Unknown'}
                    </div>
                  </td>
                  <td>
                    <div className="phone-cell">
                      <Phone size={14} />
                      {lead.phone_number}
                    </div>
                  </td>
                  <td>{lead.campaign_name || '-'}</td>
                  <td>
                    <select
                      value={lead.status}
                      onChange={(e) => updateLeadStatus(lead.id, e.target.value)}
                      className="status-select"
                      style={{
                        backgroundColor: getStatusColor(lead.status),
                        color: 'white',
                        border: 'none',
                        padding: '0.5rem',
                        borderRadius: '6px',
                        fontWeight: '600',
                        cursor: 'pointer'
                      }}
                    >
                      <option value="NEW">NEW</option>
                      <option value="CALLING">CALLING</option>
                      <option value="ANSWERED">ANSWERED</option>
                      <option value="NO_ANSWER">NO_ANSWER</option>
                      <option value="BUSY">BUSY</option>
                      <option value="FAILED">FAILED</option>
                      <option value="COMPLETED">COMPLETED</option>
                    </select>
                  </td>
                  <td>{lead.attempts || 0}</td>
                  <td>{lead.last_called ? new Date(lead.last_called).toLocaleDateString() : '-'}</td>
                  <td>{lead.next_dial_time ? new Date(lead.next_dial_time).toLocaleDateString() : '-'}</td>
                  <td>
                    <div className="lead-actions">
                      <button
                        className="btn-call"
                        title="Call Now"
                        onClick={() => callLead(lead.id, lead.phone_number)}
                      >
                        <Phone size={14} />
                      </button>
                      <button
                        className="btn-edit"
                        title="Edit Lead"
                        onClick={() => editLead(lead)}
                      >
                        <Edit size={14} />
                      </button>
                      <button
                        className="btn-notes"
                        title="View Notes"
                        onClick={() => showLeadNotes(lead)}
                        style={{
                          backgroundColor: '#9C27B0',
                          color: 'white',
                          border: 'none',
                          padding: '0.5rem',
                          borderRadius: '6px',
                          cursor: 'pointer',
                          display: 'flex',
                          alignItems: 'center',
                          justifyContent: 'center'
                        }}
                      >
                        <FileText size={14} />
                      </button>
                      <button
                        className="btn-delete"
                        title="Delete Lead"
                        onClick={() => deleteLead(lead.id, `${lead.first_name || ''} ${lead.last_name || ''}`.trim() || lead.phone_number)}
                        style={{
                          backgroundColor: '#F44336',
                          color: 'white',
                          border: 'none',
                          padding: '0.5rem',
                          borderRadius: '6px',
                          cursor: 'pointer',
                          display: 'flex',
                          alignItems: 'center',
                          justifyContent: 'center'
                        }}
                      >
                        <Trash2 size={14} />
                      </button>
                    </div>
                  </td>
                </tr>
              ))
            )}
          </tbody>
        </table>
      </div>

      {showAddModal && (
        <div className="modal-overlay" onClick={() => { setShowAddModal(false); setEditingLead(null); }}>
          <div className="modal" onClick={e => e.stopPropagation()}>
            <h3>{editingLead ? 'Edit Lead' : 'Add New Lead'}</h3>
            <input
              type="tel"
              placeholder="Phone Number"
              value={newLead.phone_number}
              onChange={e => setNewLead({...newLead, phone_number: e.target.value})}
            />
            <input
              type="text"
              placeholder="First Name"
              value={newLead.first_name}
              onChange={e => setNewLead({...newLead, first_name: e.target.value})}
            />
            <input
              type="text"
              placeholder="Last Name"
              value={newLead.last_name}
              onChange={e => setNewLead({...newLead, last_name: e.target.value})}
            />
            <select
              value={newLead.campaign_id}
              onChange={e => setNewLead({...newLead, campaign_id: e.target.value})}
            >
              <option value="">Select Campaign</option>
              {campaigns.map(c => (
                <option key={c.id} value={c.id}>{c.name}</option>
              ))}
            </select>
            <div className="modal-actions">
              <button onClick={addLead} className="btn-primary">
                {editingLead ? 'Update Lead' : 'Add Lead'}
              </button>
              <button onClick={() => { setShowAddModal(false); setEditingLead(null); }} className="btn-cancel">
                Cancel
              </button>
            </div>
          </div>
        </div>
      )}

      {showNotesModal && selectedLead && (
        <div className="modal-overlay" onClick={() => setShowNotesModal(false)}>
          <div className="modal" onClick={e => e.stopPropagation()} style={{ maxWidth: '600px', width: '90%' }}>
            <h3>Call Notes - {selectedLead.first_name} {selectedLead.last_name} ({selectedLead.phone_number})</h3>

            <div style={{ marginBottom: '1rem' }}>
              <h4 style={{ marginBottom: '0.5rem', color: '#555' }}>Previous Notes</h4>
              <div style={{ maxHeight: '300px', overflowY: 'auto', border: '1px solid #ddd', borderRadius: '6px', padding: '1rem' }}>
                {leadNotes.length === 0 ? (
                  <p style={{ color: '#999', fontStyle: 'italic' }}>No notes yet</p>
                ) : (
                  leadNotes.map((note, idx) => (
                    <div key={idx} style={{ marginBottom: '1rem', paddingBottom: '1rem', borderBottom: '1px solid #eee' }}>
                      <div style={{ display: 'flex', justifyContent: 'space-between', marginBottom: '0.5rem' }}>
                        <span style={{ fontSize: '0.85rem', color: '#999' }}>
                          {new Date(note.timestamp).toLocaleString()}
                        </span>
                        <span style={{
                          fontSize: '0.75rem',
                          padding: '0.25rem 0.5rem',
                          borderRadius: '4px',
                          backgroundColor: '#4CAF50',
                          color: 'white'
                        }}>
                          {note.call_status}
                        </span>
                      </div>
                      <p style={{ margin: '0.5rem 0', whiteSpace: 'pre-wrap' }}>{note.notes}</p>
                      {note.disposition && (
                        <span style={{ fontSize: '0.85rem', color: '#666' }}>
                          Disposition: <strong>{note.disposition}</strong>
                        </span>
                      )}
                    </div>
                  ))
                )}
              </div>
            </div>

            <div style={{ marginBottom: '1rem' }}>
              <h4 style={{ marginBottom: '0.5rem', color: '#555' }}>Add New Note</h4>
              <textarea
                placeholder="Enter note about this call..."
                value={newNote}
                onChange={e => setNewNote(e.target.value)}
                style={{
                  width: '100%',
                  minHeight: '100px',
                  padding: '0.75rem',
                  border: '1px solid #ddd',
                  borderRadius: '6px',
                  fontSize: '0.95rem',
                  fontFamily: 'inherit',
                  resize: 'vertical'
                }}
              />
            </div>

            <div className="modal-actions">
              <button onClick={addNote} className="btn-primary">Save Note</button>
              <button onClick={() => setShowNotesModal(false)} className="btn-cancel">Close</button>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}

export default LeadManager;
