; PJSIP Configuration for Exodus Dialer

[global]
type=global
debug=yes

[transport-udp]
type=transport
protocol=udp
bind=0.0.0.0:5060
tos_audio=ef
cos_audio=5

; ==================== SIP Phone Extension ====================
[1000]
type=endpoint
context=from-internal
disallow=all
allow=ulaw
allow=alaw
allow=g722
auth=1000
aors=1000
tos_audio=ef
cos_audio=5

[1000]
type=auth
auth_type=userpass
password=test1000
username=1000

[1000]
type=aor
max_contacts=5
remove_existing=yes

; ==================== Twilio SIP Trunk ====================
[twilio]
type=endpoint
transport=transport-udp
context=from-twilio
disallow=all
allow=ulaw
allow=alaw
from_user=+19544668818
outbound_auth=twilio
aors=twilio
tos_audio=ef
cos_audio=5
direct_media=no
rtp_symmetric=yes
force_rport=yes
rewrite_contact=yes

[twilio]
type=auth
auth_type=userpass
username=AC6e3e1df2a2ae9171e5e52c093fee5d77
password=your_twilio_auth_token_here

[twilio]
type=aor
contact=sip:twilio-us1.sip.twilio.com
qualify_frequency=60

[twilio]
type=identify
endpoint=twilio
match=54.172.60.0/30,54.244.51.0/30,54.171.127.192/30,35.156.191.128/30,54.65.63.192/30,54.169.127.128/30,54.252.254.64/30,177.71.206.192/30

; Registration to Twilio (if needed)
[twilio-reg]
type=registration
transport=transport-udp
outbound_auth=twilio
server_uri=sip:twilio-us1.sip.twilio.com
client_uri=sip:AC6e3e1df2a2ae9171e5e52c093fee5d77@twilio-us1.sip.twilio.com
contact_user=+19544668818
retry_interval=60
forbidden_retry_interval=600
expiration=3600
auth_rejection_permanent=no