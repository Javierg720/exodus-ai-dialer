@app.post("/bots/adjust-pool")
async def adjust_bot_pool(request: dict):
    """Adjust the number of running bots."""
    try:
        target_count = request.get("target_count", 20)
        current_count = len([b for b in bot_pool.bots.values() if b.status not in [BotStatus.CRASHED, BotStatus.STOPPED]])
        
        if target_count > current_count:
            # Start more bots
            started = 0
            for port in range(9092, 9112):
                if started >= (target_count - current_count):
                    break
                if port not in bot_pool.bots or bot_pool.bots[port].status in [BotStatus.CRASHED, BotStatus.STOPPED]:
                    await bot_pool._spawn_bot(port)
                    started += 1
            return {"message": f"Started {started} additional bots", "total_running": target_count}
        elif target_count < current_count:
            # Stop some bots
            stopped = 0
            for port in sorted(bot_pool.bots.keys(), reverse=True):
                if stopped >= (current_count - target_count):
                    break
                bot = bot_pool.bots[port]
                if bot.status == BotStatus.IDLE:
                    if bot.process:
                        bot.process.terminate()
                        bot.status = BotStatus.STOPPED
                    stopped += 1
            return {"message": f"Stopped {stopped} bots", "total_running": target_count}
        else:
            return {"message": "Bot pool already at target count", "total_running": current_count}
    except Exception as e:
        logger.error(f"Error adjusting bot pool: {e}")
        raise HTTPException(status_code=500, detail=str(e))


@app.post("/bots/{port}/start")
async def start_bot(port: int):
    """Start a specific bot instance."""
    try:
        # Check if bot already exists
        if port in bot_pool.bots:
            bot = bot_pool.bots[port]
            if bot.status in [BotStatus.CRASHED, BotStatus.STOPPED]:
                # Restart crashed or stopped bot
                await bot_pool._restart_bot(port)
                return {"message": f"Bot on port {port} restarted successfully"}
            else:
                return {"message": f"Bot on port {port} is already running"}

        await bot_pool._spawn_bot(port)
        return {"message": f"Bot on port {port} started successfully"}
    except Exception as e:
        logger.error(f"Error starting bot {port}: {e}")
        raise HTTPException(status_code=500, detail=str(e))


