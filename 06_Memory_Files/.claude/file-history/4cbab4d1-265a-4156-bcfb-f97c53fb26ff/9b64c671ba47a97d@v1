/* Component styles */
.dashboard, .bot-pool-manager, .call-history, .call-detail-page {
  background: var(--bg-primary);
  color: var(--text-primary);
  min-height: 100vh;
}

.dashboard-header {
  background: var(--bg-secondary);
  border-bottom: 1px solid var(--border);
  padding: 1rem 2rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-brand {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.header-brand h1 {
  font-size: 1.5rem;
  background: linear-gradient(135deg, var(--primary), #00a8cc);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.header-stats {
  display: flex;
  gap: 2rem;
  align-items: center;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.dashboard-nav {
  background: var(--bg-secondary);
  padding: 0 2rem;
  display: flex;
  gap: 1rem;
  border-bottom: 1px solid var(--border);
}

.nav-tab {
  background: transparent;
  border: none;
  color: var(--text-secondary);
  padding: 1rem 1.5rem;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 0.5rem;
  border-bottom: 3px solid transparent;
  transition: all 0.3s;
}

.nav-tab.active {
  color: var(--primary);
  border-bottom-color: var(--primary);
}

.dashboard-main {
  padding: 2rem;
  max-width: 1400px;
  margin: 0 auto;
}

/* Bot Pool Manager */
.bot-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));
  gap: 0.75rem;
  padding: 1.5rem;
  background: var(--bg-secondary);
  border-radius: 10px;
}

.bot-card {
  aspect-ratio: 1;
  border-radius: 8px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: var(--bg-tertiary);
  border: 2px solid var(--border);
  position: relative;
  cursor: pointer;
  transition: all 0.3s;
}

.bot-card.idle { border-color: var(--success); }
.bot-card.busy { border-color: var(--warning); }
.bot-card.stopped { border-color: var(--text-secondary); }
.bot-card.crashed { border-color: var(--danger); }

.bot-card:hover {
  transform: scale(1.05);
  z-index: 1;
}

/* Call History */
.history-table {
  width: 100%;
  background: var(--bg-secondary);
  border-radius: 10px;
  overflow: hidden;
}

.history-table thead {
  background: var(--bg-tertiary);
}

.history-table th, .history-table td {
  padding: 1rem;
  text-align: left;
  border-bottom: 1px solid var(--border);
}

.btn-view-details {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.5rem 1rem;
  background: var(--primary);
  color: white;
  text-decoration: none;
  border-radius: 6px;
  transition: all 0.3s;
}

.btn-view-details:hover {
  background: #00a8cc;
  transform: translateY(-2px);
}

/* Call Detail */
.call-detail-page {
  padding: 2rem;
  max-width: 1400px;
  margin: 0 auto;
}

.detail-content {
  display: grid;
  grid-template-columns: 350px 1fr;
  gap: 2rem;
  margin-top: 2rem;
}

.call-summary-card {
  background: var(--bg-secondary);
  border-radius: 10px;
  padding: 1.5rem;
  border: 1px solid var(--border);
}

.conversation {
  background: var(--bg-secondary);
  border-radius: 10px;
  padding: 1.5rem;
}

.conversation-turn {
  margin-bottom: 1.5rem;
  padding: 1rem;
  border-radius: 8px;
  background: var(--bg-tertiary);
}

.conversation-turn.agent {
  border-left: 4px solid var(--primary);
}

.conversation-turn.customer {
  border-left: 4px solid var(--success);
}

.audio-player {
  width: 100%;
  margin: 1rem 0;
}

/* Utilities */
.pulse {
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0% { opacity: 1; }
  50% { opacity: 0.5; }
  100% { opacity: 1; }
}

.spinning {
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
