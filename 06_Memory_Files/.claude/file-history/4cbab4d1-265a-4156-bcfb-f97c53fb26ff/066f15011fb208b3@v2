import React, { useState, useEffect } from 'react';
import { 
  Phone, Zap, Upload, Play, AlertCircle, CheckCircle,
  Users, TrendingUp, Loader, Copy, FileText, Settings
} from 'lucide-react';
import axios from 'axios';
import './BatchDial.css';

function BatchDial({ apiUrl }) {
  const [numbers, setNumbers] = useState('');
  const [campaignName, setCampaignName] = useState('');
  const [dialRatio, setDialRatio] = useState(2.0);
  const [isProcessing, setIsProcessing] = useState(false);
  const [results, setResults] = useState(null);
  const [errors, setErrors] = useState([]);
  const [autoStart, setAutoStart] = useState(true);
  const [activeBots, setActiveBots] = useState(5);
  const [currentActiveBots, setCurrentActiveBots] = useState(0);
  
  // Fetch current bot status
  useEffect(() => {
    const fetchBotStatus = async () => {
      try {
        const response = await axios.get(`${apiUrl}/bots/status`);
        const botsArray = response.data.bots || response.data;
        const active = botsArray.filter(bot => bot.status === 'busy').length;
        setCurrentActiveBots(active);
      } catch (err) {
        console.error('Failed to fetch bot status:', err);
      }
    };
    
    fetchBotStatus();
    const interval = setInterval(fetchBotStatus, 5000);
    return () => clearInterval(interval);
  }, [apiUrl]);

  const parseNumbers = (text) => {
    const lines = text.split('\n').filter(line => line.trim());
    const phoneNumbers = [];
    const parseErrors = [];

    lines.forEach((line, index) => {
      // Support multiple formats
      const parts = line.split(/[,\t|;]/).map(p => p.trim());
      let phone = '';
      let firstName = '';
      let lastName = '';

      // Try to identify phone number (10+ digits)
      parts.forEach(part => {
        const cleaned = part.replace(/[^\d]/g, '');
        if (cleaned.length >= 10 && !phone) {
          phone = part;
        } else if (!firstName && isNaN(part)) {
          firstName = part;
        } else if (!lastName && isNaN(part)) {
          lastName = part;
        }
      });

      if (phone) {
        phoneNumbers.push({
          phone_number: phone,
          first_name: firstName,
          last_name: lastName,
          line: index + 1
        });
      } else if (line.trim()) {
        parseErrors.push(`Line ${index + 1}: Invalid format - ${line}`);
      }
    });

    return { phoneNumbers, parseErrors };
  };

  const handleBatchDial = async () => {
    if (!numbers.trim()) {
      setErrors(['Please enter phone numbers']);
      return;
    }

    setIsProcessing(true);
    setErrors([]);
    setResults(null);

    try {
      // Parse the numbers
      const { phoneNumbers, parseErrors } = parseNumbers(numbers);
      
      if (parseErrors.length > 0) {
        setErrors(parseErrors);
      }

      if (phoneNumbers.length === 0) {
        setErrors(['No valid phone numbers found']);
        setIsProcessing(false);
        return;
      }

      // Generate campaign name if not provided - add timestamp to ensure uniqueness
      const timestamp = new Date().getTime();
      const finalCampaignName = campaignName.trim() 
        ? `${campaignName.trim()}_${timestamp}`
        : `Batch_Dial_${timestamp}`;

      // Step 1: Create campaign
      const campaignResponse = await axios.post(`${apiUrl}/campaigns`, {
        name: finalCampaignName,
        dial_ratio: dialRatio
      });
      const campaignId = campaignResponse.data.id;

      // Step 2: Add leads in bulk using the new bulk endpoint
      const bulkResponse = await axios.post(`${apiUrl}/leads/bulk`, {
        campaign_id: campaignId,
        leads: phoneNumbers
      });
      
      const successful = bulkResponse.data.successful;
      const failed = bulkResponse.data.errors || [];
      
      // Step 3: Start campaign if auto-start is enabled
      let campaignStarted = false;
      let callsInitiated = 0;
      if (autoStart && successful > 0) {
        try {
          await axios.put(`${apiUrl}/campaigns/${campaignId}/status`, { status: 'ACTIVE' });
          campaignStarted = true;
          
          // Adjust bot pool if needed
          if (activeBots > 0) {
            await axios.post(`${apiUrl}/bots/adjust-pool`, {
              target_count: activeBots
            });
          }
          
          // Actually dial each lead
          for (const lead of phoneNumbers.slice(0, Math.min(phoneNumbers.length, activeBots))) {
            try {
              await axios.post(`${apiUrl}/calls/originate`, {
                phone_number: lead.phone_number,
                campaign_id: campaignId
              });
              callsInitiated++;
            } catch (err) {
              console.error(`Failed to dial ${lead.phone_number}:`, err);
            }
          }
        } catch (err) {
          console.error('Failed to start campaign:', err);
        }
      }

      // Set results
      setResults({
        campaignId,
        campaignName: finalCampaignName,
        totalNumbers: phoneNumbers.length,
        successful,
        failed: failed.length,
        campaignStarted,
        activeBots: campaignStarted ? activeBots : 0,
        callsInitiated: callsInitiated || 0,
        failedDetails: failed
      });

      // Clear form if successful
      if (successful > 0) {
        setNumbers('');
        setCampaignName('');
      }

    } catch (error) {
      console.error('Batch Dial Error:', error);
      const errorMessage = error.response?.data?.detail || 
                          error.response?.data?.message || 
                          error.message || 
                          'Failed to process batch dial';
      setErrors([errorMessage]);
    } finally {
      setIsProcessing(false);
    }
  };

  const handlePasteExample = () => {
    setNumbers(`555-0100, John, Smith
555-0101, Jane, Doe
555-0102, Bob, Johnson
555-0103
555-0104, Alice
(555) 010-5678
+1-555-010-9012`);
  };

  const getNumberCount = () => {
    if (!numbers.trim()) return 0;
    const { phoneNumbers } = parseNumbers(numbers);
    return phoneNumbers.length;
  };

  const getPreviewNumbers = () => {
    if (!numbers.trim()) return [];
    const { phoneNumbers } = parseNumbers(numbers);
    return phoneNumbers.slice(0, 5);
  };

  return (
    <div className="batch-dial">
      <div className="batch-header">
        <div className="batch-title">
          <div className="batch-title-icon">
            <Zap size={30} />
          </div>
          <h2>Batch Dial</h2>
        </div>
        <div className="batch-stats">
          <div className="batch-stat">
            <Users size={20} style={{color: '#667eea'}} />
            <div>
              <div className="batch-stat-value">{getNumberCount()}</div>
              <div className="batch-stat-label">Numbers Ready</div>
            </div>
          </div>
          <div className="batch-stat">
            <Phone size={20} style={{color: currentActiveBots > 0 ? '#28a745' : '#999'}} />
            <div>
              <div className="batch-stat-value">{currentActiveBots}</div>
              <div className="batch-stat-label">Active Bots</div>
            </div>
          </div>
        </div>
      </div>

      <div className="batch-main">
        <div className="batch-input-section">
          <div className="input-header">
            <h3>
              <Upload size={20} />
              Phone Numbers
            </h3>
            <div className="format-examples" onClick={handlePasteExample}>
              <FileText size={14} />
              Paste Example
            </div>
          </div>
          
          <div className="input-body">
            <input
              type="text"
              className="campaign-name-input"
              placeholder="Campaign Name (optional - auto-generated if empty)"
              value={campaignName}
              onChange={(e) => setCampaignName(e.target.value)}
            />
            
            <textarea
              className="numbers-textarea"
              placeholder="Paste phone numbers here...

Supported formats:
• 555-0100, John, Smith
• 555-0101
• (555) 010-5678
• +1-555-010-9012, Jane, Doe

You can use comma, tab, or pipe separators"
              value={numbers}
              onChange={(e) => setNumbers(e.target.value)}
            />
          </div>
        </div>

        <div className="batch-config-section">
          <div className="config-card">
            <h3>
              <Settings size={18} />
              Dial Settings
            </h3>
            
            <div className="config-item">
              <label>Dial Ratio</label>
              <input
                type="range"
                className="config-slider"
                min="1"
                max="5"
                step="0.5"
                value={dialRatio}
                onChange={(e) => setDialRatio(parseFloat(e.target.value))}
                style={{'--value': `${((dialRatio - 1) / 4) * 100}%`}}
              />
              <div className="config-value">
                <span>{dialRatio}x</span>
                <span className="text-muted">calls per bot</span>
              </div>
            </div>

            <div className="config-item">
              <label>Active Bots</label>
              <input
                type="range"
                className="config-slider"
                min="1"
                max="20"
                value={activeBots}
                onChange={(e) => setActiveBots(parseInt(e.target.value))}
                style={{'--value': `${((activeBots - 1) / 19) * 100}%`}}
              />
              <div className="config-value">
                <span>{activeBots}</span>
                <span className="text-muted">bots</span>
              </div>
            </div>

            <div className="config-item">
              <label>Auto Start</label>
              <div className="auto-start-toggle">
                <label className="toggle-switch">
                  <input
                    type="checkbox"
                    checked={autoStart}
                    onChange={(e) => setAutoStart(e.target.checked)}
                  />
                  <span className="toggle-slider"></span>
                </label>
                <span>{autoStart ? 'Start immediately' : 'Manual start'}</span>
              </div>
            </div>
          </div>

          <div className="batch-actions">
            <button
              className={`batch-button primary ${isProcessing ? 'loading' : ''}`}
              onClick={handleBatchDial}
              disabled={isProcessing || getNumberCount() === 0}
            >
              {isProcessing ? (
                <>
                  <Loader className="loading-spinner" size={18} />
                  Processing...
                </>
              ) : (
                <>
                  <Zap size={18} />
                  Start Batch Dial
                </>
              )}
            </button>
          </div>

          {autoStart && (
            <div className="config-card" style={{marginTop: '20px'}}>
              <div style={{fontSize: '13px', color: '#666', display: 'flex', alignItems: 'center', gap: '8px'}}>
                <AlertCircle size={14} />
                Campaign will start with {activeBots} bots
              </div>
            </div>
          )}
        </div>
      </div>

      {/* Preview Section */}
      {getNumberCount() > 0 && !results && (
        <div className="preview-section">
          <div className="preview-header">
            <h3>Preview</h3>
            <div className="preview-count">{getNumberCount()} numbers</div>
          </div>
          <div className="preview-list">
            {getPreviewNumbers().map((num, i) => (
              <div key={i} className="preview-item">
                <div className="preview-item-info">
                  <div className="preview-item-phone">{num.phone_number}</div>
                  {(num.first_name || num.last_name) && (
                    <div className="preview-item-name">
                      {num.first_name} {num.last_name}
                    </div>
                  )}
                </div>
                <div className="preview-item-line">Line {num.line}</div>
              </div>
            ))}
            {getNumberCount() > 5 && (
              <div style={{textAlign: 'center', padding: '10px', color: '#666'}}>
                ... and {getNumberCount() - 5} more
              </div>
            )}
          </div>
        </div>
      )}

      {/* Error Section */}
      {errors.length > 0 && (
        <div className="error-list">
          <h4>
            <AlertCircle size={16} />
            Issues Found
          </h4>
          {errors.map((error, i) => (
            <div key={i} className="error-item">
              {error}
            </div>
          ))}
        </div>
      )}

      {/* Results Section */}
      {results && (
        <div className="results-section">
          <div className="results-header">
            <CheckCircle size={24} />
            <div>
              <h3>Batch Dial Complete!</h3>
              <p>Campaign: {results.campaignName}</p>
            </div>
          </div>
          
          <div className="results-stats">
            <div className="result-stat">
              <div className="result-stat-value">{results.successful}</div>
              <div className="result-stat-label">Added</div>
            </div>
            <div className="result-stat">
              <div className="result-stat-value">{results.failed}</div>
              <div className="result-stat-label">Failed</div>
            </div>
            {results.campaignStarted && (
              <div className="result-stat">
                <div className="result-stat-value">{results.activeBots}</div>
                <div className="result-stat-label">Bots Active</div>
              </div>
            )}
            <div className="result-stat">
              <div className="result-stat-value" style={{fontSize: '18px'}}>
                {results.campaignStarted ? '🟢 Running' : '⏸️ Ready'}
              </div>
              <div className="result-stat-label">Status</div>
            </div>
          </div>

          {results.failedDetails && results.failedDetails.length > 0 && (
            <div className="error-list" style={{marginTop: '20px'}}>
              <h4>Failed Numbers:</h4>
              {results.failedDetails.map((fail, i) => (
                <div key={i} className="error-item">
                  {fail.phone}: {fail.error}
                </div>
              ))}
            </div>
          )}
        </div>
      )}
    </div>
  );
}

export default BatchDial;