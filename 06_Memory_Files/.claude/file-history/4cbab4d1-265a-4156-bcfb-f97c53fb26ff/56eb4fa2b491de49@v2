/* Apple-Inspired Dashboard Design */

.dashboard-apple {
  min-height: 100vh;
  background: #000;
  color: white;
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", sans-serif;
  position: relative;
  overflow-x: hidden;
}

/* Navigation Tabs */
.apple-nav-tabs {
  position: fixed;
  top: 44px;
  left: 0;
  right: 0;
  height: 48px;
  background: rgba(28, 28, 30, 0.95);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border-bottom: 0.5px solid rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 0 20px;
  z-index: 999;
}

.apple-tab {
  padding: 8px 16px;
  background: transparent;
  border: none;
  color: rgba(255, 255, 255, 0.6);
  font-size: 13px;
  font-weight: 500;
  border-radius: 8px;
  cursor: pointer;
  transition: all 0.2s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  display: flex;
  align-items: center;
  gap: 6px;
}

.apple-tab:hover {
  background: rgba(255, 255, 255, 0.05);
  color: white;
}

.apple-tab.active {
  background: rgba(10, 132, 255, 0.2);
  color: #0a84ff;
}

/* Section Wrapper */
.apple-section-wrapper {
  padding: 20px;
  max-width: 1400px;
  margin: 0 auto;
  animation: fadeIn 0.3s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

/* Animated gradient background */
.dashboard-apple::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: 
    radial-gradient(circle at 20% 50%, rgba(10, 132, 255, 0.15) 0%, transparent 50%),
    radial-gradient(circle at 80% 80%, rgba(48, 209, 88, 0.1) 0%, transparent 50%),
    radial-gradient(circle at 40% 20%, rgba(191, 90, 242, 0.1) 0%, transparent 50%);
  animation: gradientShift 20s ease-in-out infinite;
  pointer-events: none;
  z-index: 0;
}

@keyframes gradientShift {
  0%, 100% { transform: scale(1) rotate(0deg); }
  50% { transform: scale(1.2) rotate(180deg); }
}

/* Status Bar - iOS style */
.status-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 44px;
  background: rgba(0, 0, 0, 0.8);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20px;
  border-bottom: 0.5px solid rgba(255, 255, 255, 0.1);
}

.status-left, .status-right {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  font-weight: 600;
}

.status-time {
  letter-spacing: -0.01em;
}

/* Dynamic Island */
.dynamic-island {
  background: #1c1c1e;
  border-radius: 20px;
  padding: 4px 12px;
  min-width: 120px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.dynamic-island:hover {
  transform: scale(1.05);
  background: #2c2c2e;
}

.island-content {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  font-weight: 600;
}

.island-content .pulse {
  animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

/* Battery indicator */
.battery {
  width: 24px;
  height: 12px;
  border: 1px solid rgba(255, 255, 255, 0.35);
  border-radius: 2.5px;
  padding: 1px;
  position: relative;
}

.battery::after {
  content: '';
  position: absolute;
  right: -3px;
  top: 3px;
  width: 1px;
  height: 6px;
  background: rgba(255, 255, 255, 0.35);
  border-radius: 0 1px 1px 0;
}

.battery-fill {
  height: 100%;
  background: #30d158;
  border-radius: 1.5px;
}

/* Main Content */
.dashboard-content {
  padding: 60px 20px 20px;
  position: relative;
  z-index: 1;
  max-width: 1400px;
  margin: 0 auto;
}

/* Hero Section */
.hero-section {
  padding: 40px 0;
  text-align: center;
}

.hero-title {
  font-size: 48px;
  font-weight: 700;
  letter-spacing: -0.03em;
  margin: 0;
  background: linear-gradient(180deg, #fff 0%, rgba(255, 255, 255, 0.8) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.hero-subtitle {
  font-size: 20px;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 8px;
  letter-spacing: -0.01em;
}

/* Activity Rings Container */
.activity-rings-container {
  display: flex;
  justify-content: center;
  gap: 20px;
  margin: 40px 0;
  flex-wrap: wrap;
}

.activity-ring-card {
  padding: 30px;
  display: flex;
  gap: 40px;
  align-items: center;
}

/* Glass Card Effect */
.glass-card {
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(40px) saturate(180%);
  -webkit-backdrop-filter: blur(40px) saturate(180%);
  border-radius: 24px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.glass-card:hover {
  background: rgba(255, 255, 255, 0.08);
  transform: translateY(-2px);
  box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
}

/* Activity Ring */
.ring-wrapper {
  position: relative;
  width: 140px;
  height: 140px;
}

.activity-ring {
  transform: rotate(-90deg);
}

.ring-bg {
  fill: none;
  stroke: rgba(255, 255, 255, 0.1);
  stroke-width: 10;
}

.ring-fill {
  fill: none;
  stroke-width: 10;
  stroke-linecap: round;
  transition: stroke-dasharray 1s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.ring-calls {
  stroke: #0a84ff;
}

.ring-success {
  stroke: #30d158;
}

.ring-active {
  stroke: #ff9f0a;
}

.ring-center {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
}

.ring-value {
  font-size: 32px;
  font-weight: 700;
  letter-spacing: -0.02em;
}

.ring-label {
  font-size: 10px;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.5);
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

/* Ring Legend */
.ring-legend {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 14px;
}

.legend-dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
}

.legend-dot.calls { background: #0a84ff; }
.legend-dot.success { background: #30d158; }
.legend-dot.active { background: #ff9f0a; }

.legend-value {
  margin-left: auto;
  font-weight: 600;
}

/* Control Center */
.control-center {
  margin: 40px 0;
}

.control-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
  grid-auto-rows: minmax(100px, auto);
}

.control-tile {
  padding: 20px;
  cursor: pointer;
  position: relative;
  overflow: hidden;
}

.control-tile.large {
  grid-column: span 2;
  grid-row: span 2;
}

.control-tile.medium {
  grid-column: span 1;
  grid-row: span 2;
}

.control-tile.small {
  grid-column: span 1;
  grid-row: span 1;
}

.control-icon {
  width: 48px;
  height: 48px;
  background: linear-gradient(135deg, #0a84ff, #0a7ff5);
  border-radius: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16px;
}

.control-info {
  margin-bottom: 16px;
}

.control-value {
  font-size: 36px;
  font-weight: 700;
  letter-spacing: -0.02em;
}

.control-label {
  font-size: 14px;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 4px;
}

/* iOS Slider */
.control-slider {
  margin-top: 20px;
}

.ios-slider {
  width: 100%;
  height: 28px;
  -webkit-appearance: none;
  appearance: none;
  background: transparent;
  outline: none;
}

.ios-slider::-webkit-slider-track {
  width: 100%;
  height: 6px;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 3px;
}

.ios-slider::-webkit-slider-thumb {
  -webkit-appearance: none;
  appearance: none;
  width: 28px;
  height: 28px;
  background: white;
  border-radius: 50%;
  cursor: pointer;
  box-shadow: 0 3px 10px rgba(0, 0, 0, 0.3);
  transition: all 0.2s;
}

.ios-slider::-webkit-slider-thumb:hover {
  transform: scale(1.1);
}

/* Tile Headers */
.tile-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12px;
}

.tile-badge {
  background: #ff453a;
  color: white;
  font-size: 11px;
  font-weight: 600;
  padding: 2px 6px;
  border-radius: 10px;
  min-width: 18px;
  text-align: center;
}

.tile-content {
  margin-top: auto;
}

.tile-value {
  font-size: 28px;
  font-weight: 700;
  letter-spacing: -0.02em;
}

.tile-label {
  font-size: 13px;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 2px;
}

.tile-micro {
  font-size: 11px;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 2px;
}

/* Mini Chart */
.mini-chart {
  display: flex;
  align-items: flex-end;
  gap: 2px;
  height: 40px;
  margin-top: 12px;
}

.chart-bar {
  flex: 1;
  background: linear-gradient(to top, #0a84ff, #0a7ff5);
  border-radius: 2px 2px 0 0;
  opacity: 0.8;
}

/* Compliance Indicator */
.compliance-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  margin: 0 auto 8px;
}

.compliance-indicator.compliant {
  color: #30d158;
}

.compliance-indicator.warning {
  color: #ff9f0a;
}

/* Action Tiles */
.action-tile {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8px;
  transition: all 0.2s;
}

.action-tile:hover {
  background: rgba(255, 255, 255, 0.1);
  transform: scale(1.05);
}

.action-tile:active {
  transform: scale(0.95);
}

/* Live Activities */
.live-activities {
  margin: 40px 0;
}

.section-title {
  font-size: 22px;
  font-weight: 600;
  margin-bottom: 16px;
  letter-spacing: -0.02em;
}

.activity-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.activity-card {
  padding: 16px;
  display: flex;
  align-items: center;
  gap: 16px;
}

.pulse-container {
  position: relative;
}

.pulse-ring {
  position: absolute;
  top: -8px;
  left: -8px;
  right: -8px;
  bottom: -8px;
  border: 2px solid #30d158;
  border-radius: 50%;
  animation: pulseRing 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
}

@keyframes pulseRing {
  0% {
    transform: scale(0.95);
    opacity: 1;
  }
  50% {
    transform: scale(1.3);
    opacity: 0;
  }
  100% {
    transform: scale(0.95);
    opacity: 0;
  }
}

.activity-icon {
  width: 36px;
  height: 36px;
  background: linear-gradient(135deg, #30d158, #2fc754);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.activity-details {
  flex: 1;
}

.activity-title {
  font-size: 15px;
  font-weight: 600;
}

.activity-status {
  font-size: 13px;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 2px;
}

/* Waveform Animation */
.waveform {
  display: flex;
  align-items: center;
  gap: 1px;
  height: 30px;
}

.wave-bar {
  width: 2px;
  background: #30d158;
  border-radius: 1px;
  animation: wave 1s ease-in-out infinite;
  animation-delay: calc(var(--i) * 0.05s);
}

.wave-bar:nth-child(odd) {
  animation-duration: 0.8s;
}

@keyframes wave {
  0%, 100% { height: 20%; }
  50% { height: 100%; }
}

/* Widget Grid */
.widget-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 16px;
  margin: 40px 0;
}

.widget {
  padding: 20px;
}

.widget-header {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 12px;
}

.widget-value {
  font-size: 32px;
  font-weight: 700;
  letter-spacing: -0.02em;
  margin-bottom: 12px;
}

.widget-subtitle {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.5);
}

.widget-trend {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: 12px;
  font-weight: 600;
}

.widget-trend.up {
  color: #30d158;
}

.widget-trend.down {
  color: #ff453a;
}

/* Progress Bar */
.widget-progress {
  margin-top: 12px;
}

.progress-bar {
  height: 6px;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 3px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #0a84ff, #0a7ff5);
  border-radius: 3px;
  transition: width 1s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

/* Spark Line */
.spark-line {
  display: flex;
  align-items: flex-end;
  gap: 3px;
  height: 40px;
}

.spark-bar {
  flex: 1;
  background: linear-gradient(to top, rgba(10, 132, 255, 0.3), rgba(10, 132, 255, 0.8));
  border-radius: 2px 2px 0 0;
}

/* FAB - Floating Action Button */
.fab {
  position: fixed;
  bottom: 30px;
  right: 30px;
  width: 60px;
  height: 60px;
  background: linear-gradient(135deg, #0a84ff, #0a7ff5);
  border: none;
  border-radius: 30px;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  box-shadow: 0 10px 30px rgba(10, 132, 255, 0.3);
  transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  z-index: 100;
}

.fab:hover {
  transform: scale(1.1) rotate(90deg);
  box-shadow: 0 15px 40px rgba(10, 132, 255, 0.4);
}

.fab:active {
  transform: scale(0.95);
}

/* Responsive */
@media (max-width: 1024px) {
  .control-grid {
    grid-template-columns: repeat(2, 1fr);
  }
  
  .activity-ring-card {
    flex-direction: column;
  }
}

@media (max-width: 640px) {
  .hero-title {
    font-size: 32px;
  }
  
  .control-grid {
    grid-template-columns: 1fr;
  }
  
  .widget-grid {
    grid-template-columns: 1fr;
  }
}