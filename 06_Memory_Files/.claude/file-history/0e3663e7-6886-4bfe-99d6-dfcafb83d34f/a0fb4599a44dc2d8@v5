const express = require('express');
const axios = require('axios');

const app = express();
app.use(express.json());

const PORT = process.env.PORT || 6002;
const CEREBRAS_API_KEY = process.env.CEREBRAS_API_KEY;
const MODEL = process.env.CEREBRAS_MODEL || 'llama-3.3-70b';
const TEMPERATURE = parseFloat(process.env.TEMPERATURE || '0.7');
const MAX_TOKENS = parseInt(process.env.MAX_TOKENS || '1000');
const TOP_P = parseFloat(process.env.TOP_P || '0.95');
const SYSTEM_PROMPT = process.env.SYSTEM_PROMPT || 'You are a helpful AI assistant.';

const cerebras = axios.create({
  baseURL: 'https://api.cerebras.ai/v1',
  headers: {
    'Authorization': `Bearer ${CEREBRAS_API_KEY}`,
    'Content-Type': 'application/json'
  }
});

// Health check
app.get('/health', (req, res) => {
  res.json({
    status: 'ok',
    provider: 'cerebras',
    model: MODEL
  });
});

// AVR-compatible prompt-stream endpoint - BUFFERED RESPONSE
app.post('/prompt-stream', async (req, res) => {
  try {
    const { messages = [], systemPrompt = SYSTEM_PROMPT } = req.body;

    const formattedMessages = [
      { role: 'system', content: systemPrompt },
      ...messages.map(msg => ({
        role: msg.role || 'user',
        content: msg.content || msg.text || ''
      }))
    ];

    console.log(`[Cerebras] /prompt-stream request with ${messages.length} messages`);

    // Get complete response (non-streaming)
    const response = await cerebras.post('/chat/completions', {
      model: MODEL,
      messages: formattedMessages,
      temperature: TEMPERATURE,
      max_completion_tokens: MAX_TOKENS,
      top_p: TOP_P,
      stream: false  // Get complete response
    });

    const responseText = response.data.choices[0]?.message?.content || '';

    console.log(`[Cerebras] Response: ${responseText.substring(0, 50)}...`);

    // AVR Core expects "type" and "content" fields
    res.json({
      type: 'text',
      content: responseText
    });

  } catch (error) {
    console.error('[Cerebras] /prompt-stream error:', error.message);
    res.status(500).json({ error: error.message });
  }
});

// Legacy /chat endpoint (for compatibility)
app.post('/chat', async (req, res) => {
  try {
    const { prompt, system = SYSTEM_PROMPT } = req.body;

    const response = await cerebras.post('/chat/completions', {
      model: MODEL,
      messages: [
        { role: 'system', content: system },
        { role: 'user', content: prompt }
      ],
      temperature: TEMPERATURE,
      max_completion_tokens: MAX_TOKENS,
      top_p: TOP_P
    });

    const responseText = response.data.choices[0]?.message?.content || '';
    res.json({ response: responseText });

  } catch (error) {
    console.error('[Cerebras] /chat error:', error.message);
    res.status(500).json({ error: error.message });
  }
});

app.listen(PORT, '0.0.0.0', () => {
  console.log(`[Cerebras LLM Provider] Running on port ${PORT}`);
  console.log(`[Cerebras] Model: ${MODEL}`);
  console.log(`[Cerebras] Temperature: ${TEMPERATURE}`);
});
