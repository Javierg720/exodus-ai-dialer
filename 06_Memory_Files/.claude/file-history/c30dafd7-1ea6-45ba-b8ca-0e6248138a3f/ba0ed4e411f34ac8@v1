; ============================================================================
; Installation Instructions:
; ============================================================================
; 1. Copy this configuration to /etc/asterisk/extensions.conf
;    (or include it: #include "asterisk-dialer-config.conf")
;
; 2. Reload Asterisk dialplan:
;    asterisk -rx "dialplan reload"
;
; 3. Verify configuration:
;    asterisk -rx "dialplan show audiosocket-dial"
; ============================================================================

; ============================================================================
; AVR AGENT OUTBOUND CALLING
; ============================================================================
[avr-outbound]
; Route outbound calls from dialer to AVR agent
exten => s,1,NoOp(Outbound call to AVR agent)
 same => n,Answer()
 same => n,Wait(2)
 same => n,Set(UUID=${SHELL(uuidgen | tr -d '\n')})
 same => n,Dial(AudioSocket/avr-core-9e36ac23-98bb-4cda-91fe-a261763976c8:5370/${UUID})
 same => n,Hangup()
