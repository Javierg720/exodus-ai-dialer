@app.post("/system/reboot")
async def reboot_system():
    """Reboot the entire dialer system (API + orchestrator + bots)."""
    import subprocess
    import os

    logger.info("🔄 SYSTEM REBOOT: Initiating system reboot...")

    try:
        # Restart all bots first
        try:
            from avr_bot_manager import AVRBotManager

            avr_manager = AVRBotManager()
            running_bots = avr_manager.get_running_bots()
            for bot in running_bots:
                port = bot.get("port")
                if port:
                    try:
                        avr_manager.restart_bot(port)
                    except:
                        pass
        except:
            pass

        # Schedule API restart in background
        script_path = os.path.abspath(__file__)
        subprocess.Popen(
            f"sleep 2 && pkill -f 'python.*dialer_api' && sleep 1 && python {script_path} &",
            shell=True,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )

        logger.info("✅ SYSTEM REBOOT: Reboot scheduled")
        return {
            "status": "success",
            "message": "System reboot initiated. Please wait 5-10 seconds and refresh.",
        }
    except Exception as e:
        logger.error(f"❌ SYSTEM REBOOT: Failed - {str(e)}", exc_info=True)
        raise HTTPException(status_code=500, detail=str(e))


