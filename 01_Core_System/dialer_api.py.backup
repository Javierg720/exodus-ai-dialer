@app.get("/dnc")
async def list_dnc(limit: int = 100, offset: int = 0):
    """List all numbers in DNC list."""
    logger.info(
        f"📋 LIST DNC: Request to list DNC entries, limit={limit}, offset={offset}"
    )

    try:
        async with db.db.execute(
            """
            SELECT * FROM dnc_list
            ORDER BY added_at DESC
            LIMIT ? OFFSET ?
            """,
            (limit, offset),
        ) as cursor:
            rows = await cursor.fetchall()

        logger.info(f"✅ LIST DNC: Retrieved {len(rows)} DNC entries")
        if rows and len(rows) > 0:
            logger.debug(f"   Most recent: {dict(rows[0]).get('phone_number', 'N/A')}")

        # Return just the array for frontend compatibility
        return [dict(row) for row in rows]
    except Exception as e:
        logger.error(f"❌ LIST DNC: Failed - {str(e)}", exc_info=True)
        raise HTTPException(status_code=500, detail=str(e))


