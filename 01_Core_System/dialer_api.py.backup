@app.get("/stats")
async def get_stats():
    """Get real-time dialer statistics."""
    logger.info("📊 GET STATS: Request for real-time dialer statistics")
    try:
        # Get today's call stats from database
        today_stats = await db.get_todays_stats()

        # Get active lead counts
        lead_stats = await db.get_lead_stats()

        # Get compliance stats
        drop_rate_30d = await db.calculate_drop_rate(days=30)

        # Base orchestrator stats
        if orchestrator is None:
            # Return basic stats from database when orchestrator is unavailable
            logger.info("📦 Orchestrator unavailable - returning database stats only")
            base_stats = {
                "active_calls": 0,
                "dialing": 0,
                "answered": 0,
                "current_dial_ratio": 0.0,
                "bot_pool": {"mode": "avr_docker", "total": 20, "idle": 20, "busy": 0},
            }
        else:
            base_stats = orchestrator.get_statistics()

        # Combine all stats for full dashboard data
        full_stats = {
            **base_stats,
            # Today's call data
            "todaysCalls": today_stats.get("total_calls", 0),
            "todaysAnswered": today_stats.get("answered", 0),
            # Lead data
            "newLeads": lead_stats.get("new", 0),
            "totalLeads": lead_stats.get("total", 0),
            "calledLeads": lead_stats.get("called", 0),
            # Compliance
            "dropRate": round(drop_rate_30d * 100, 2),
            # Analytics data for Analytics component
            "today_calls": {
                "total_calls": today_stats.get("total_calls", 0),
                "answered": today_stats.get("answered", 0),
                "no_answer": today_stats.get("no_answer", 0),
                "busy": today_stats.get("busy", 0),
                "failed": today_stats.get("failed", 0),
                "avg_duration": today_stats.get("avg_duration", 0),
            },
            "compliance": {
                "compliant": drop_rate_30d < 0.03,
                "drop_rate_30d": round(drop_rate_30d * 100, 2),
            },
            "leads": lead_stats,
            "disposition_breakdown": today_stats.get("dispositions", {}),
        }

        logger.debug(
            f"   Today's Calls: {full_stats['todaysCalls']}, Answered: {full_stats['todaysAnswered']}"
        )
        logger.debug(f"   30-Day Drop Rate: {full_stats['dropRate']}%")
        return full_stats
    except Exception as e:
        logger.error(f"❌ GET STATS: Failed - {str(e)}", exc_info=True)
        raise HTTPException(status_code=500, detail=str(e))


