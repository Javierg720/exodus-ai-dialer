networks:
  avr-net:
    driver: bridge
    name: avr-net

services:
  # ASR Service - Updated with Deepgram SDK v5 and raw PCM support
  avr-asr:
    container_name: avr-asr-deepgram
    build:
      context: .
      dockerfile: Dockerfile.asr-v5
    image: avr-asr-deepgram:v5
    environment:
      - PORT=6010
      - DEEPGRAM_API_KEY=${DEEPGRAM_API_KEY}
      - SPEECH_RECOGNITION_LANGUAGE=en-US
      - SPEECH_RECOGNITION_MODEL=nova-2-phonecall
      - ENABLE_DENOISING=false
      - NOISE_THRESHOLD=1.5
    networks:
      avr-net:
        aliases:
          - avr-asr
    platform: linux/x86_64
    restart: always

  # LLM Service - Groq with network alias
  avr-llm:
    container_name: avr-llm-groq
    environment:
      - PORT=6002
      - GROQ_API_KEY=${GROQ_API_KEY}
      - GROQ_MODEL=llama-3.3-70b-versatile
      - TEMPERATURE=0.6
    image: avr-llm-groq:latest
    networks:
      avr-net:
        aliases:
          - avr-llm
          - avr-llm-groq
    platform: linux/x86_64
    restart: always

  # TTS Service - Edge TTS with network alias
  avr-tts:
    container_name: avr-tts-edge
    environment:
      - PORT=6011
      - VOICE=en-US-AvaMultilingualNeural
      - RATE=+30%
      - PITCH=+0Hz
      - VOLUME=+0%
    image: avr-tts-edge:latest
    networks:
      avr-net:
        aliases:
          - avr-tts
          - avr-tts-edge
    platform: linux/x86_64
    restart: always

  # Bot Pool - 20 bots with improved VAD settings
  avr-bot-9092:
    container_name: avr-bot-9092
    depends_on:
      - avr-asr
      - avr-llm
      - avr-tts
    environment:
      - PORT=9092
      - ASR_URL=http://avr-asr:6010/speech-to-text-stream
      - LLM_URL=http://avr-llm:6002/prompt-stream
      - TTS_URL=http://avr-tts:6011/text-to-speech-stream
      - INTERRUPT_LISTENING=false
      - MIN_SPEECH_MS=150
      - VAD_SENSITIVITY=0
      - ENERGY_THRESHOLD=150
      - ASR_TIMEOUT_MS=2500
      - MAX_BUFFER_MS=2500
      - SILENCE_THRESHOLD_DB=-35
      - SYSTEM_MESSAGE=Hey there, Ava with Fund Express. Calling about the money you were seeking for the business. Did you secure those funds?
    image: agentvoiceresponse/avr-core
    networks:
      - avr-net
    platform: linux/x86_64
    ports:
      - 9092:9092
    restart: always

  avr-bot-9093:
    container_name: avr-bot-9093
    depends_on:
      - avr-asr
      - avr-llm
      - avr-tts
    environment:
      - PORT=9093
      - ASR_URL=http://avr-asr:6010/speech-to-text-stream
      - LLM_URL=http://avr-llm:6002/prompt-stream
      - TTS_URL=http://avr-tts:6011/text-to-speech-stream
      - INTERRUPT_LISTENING=false
      - MIN_SPEECH_MS=200
      - VAD_SENSITIVITY=1
      - SYSTEM_MESSAGE=Hey there, Ava with Fund Express. Calling about the money you were seeking for the business. Did you secure those funds?
    image: agentvoiceresponse/avr-core
    networks:
      - avr-net
    platform: linux/x86_64
    ports:
      - 9093:9093
    restart: always

  avr-bot-9094:
