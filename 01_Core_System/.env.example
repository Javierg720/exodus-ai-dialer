# ============================================
# EXODUS VOICE AI SYSTEM - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your actual API keys
# NEVER commit .env to version control!

# ============================================
# API KEYS - REQUIRED
# ============================================

# Deepgram API Key for ASR (Speech Recognition) and TTS
# Get your key from: https://console.deepgram.com/
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Groq API Key for LLM (Language Model)
# Get your key from: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Cerebras API Key for Alternative LLM (Optional)
# Get your key from: https://cerebras.ai/
CEREBRAS_API_KEY=your_cerebras_api_key_here

# ============================================
# ASR SERVICE CONFIGURATION
# ============================================

ASR_PORT=6010
ASR_LANGUAGE=en-US
ASR_MODEL=nova-2-phonecall
ASR_SAMPLE_RATE=8000
ASR_ENABLE_DENOISING=false
ASR_NOISE_THRESHOLD=1.5

# ============================================
# LLM SERVICE CONFIGURATION
# ============================================

# Groq LLM Settings
GROQ_PORT=6002
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.6

# Cerebras LLM Settings (Alternative)
CEREBRAS_PORT=6003
CEREBRAS_MODEL=llama3.1-8b
CEREBRAS_TEMPERATURE=0.6

# ============================================
# TTS SERVICE CONFIGURATION
# ============================================

TTS_PORT=6011
TTS_VOICE=en-US-AvaMultilingualNeural
TTS_RATE=+30%
TTS_PITCH=+0Hz
TTS_VOLUME=+0%

# ============================================
# BOT CONFIGURATION
# ============================================

# Voice Agent Behavior Settings
BOT_INTERRUPT_LISTENING=false
BOT_MIN_SPEECH_MS=150
BOT_VAD_SENSITIVITY=0
BOT_ENERGY_THRESHOLD=150
BOT_ASR_TIMEOUT_MS=2500
BOT_MAX_BUFFER_MS=2500
BOT_SILENCE_THRESHOLD_DB=-35

# Default System Message (Opening Pitch)
BOT_SYSTEM_MESSAGE=Hey there, Ava with Fund Express. Calling about the money you were seeking for the business. Did you secure those funds?

# ============================================
# RESOURCE LIMITS
# ============================================

# ASR Service Resources
ASR_MEMORY_LIMIT=2G
ASR_MEMORY_RESERVATION=1G
ASR_CPU_LIMIT=2

# LLM Service Resources
LLM_MEMORY_LIMIT=4G
LLM_MEMORY_RESERVATION=2G
LLM_CPU_LIMIT=2

# TTS Service Resources
TTS_MEMORY_LIMIT=1G
TTS_MEMORY_RESERVATION=512M
TTS_CPU_LIMIT=1

# Bot Service Resources
BOT_MEMORY_LIMIT=512M
BOT_MEMORY_RESERVATION=256M
BOT_CPU_LIMIT=0.5

# ============================================
# HEALTH CHECK CONFIGURATION
# ============================================

HEALTHCHECK_INTERVAL=30s
HEALTHCHECK_TIMEOUT=10s
HEALTHCHECK_RETRIES=3
HEALTHCHECK_START_PERIOD=40s
